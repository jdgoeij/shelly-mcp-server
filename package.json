{
  "name": "shelly-mcp-server",
  "version": "0.1.0",
  "description": "Local MCP server for controlling Shelly devices over LAN",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "bin": {
    "shelly-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "discovery.config.example.json",
    ".env.example",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "prepack": "npm run build"
  },
  "keywords": [
    "mcp",
    "shelly",
    "home-automation"
  ],
  "author": "Jaap de Goeij",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jdgoeij/shelly-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/jdgoeij/shelly-mcp-server/issues"
  },
  "homepage": "https://github.com/jdgoeij/shelly-mcp-server#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "dotenv": "^17.4.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.6",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
