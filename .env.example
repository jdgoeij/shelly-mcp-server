# Option A: point to a JSON file with your devices (recommended)
SHELLY_DEVICES_FILE=./devices.local.json

# Option B: inline JSON (leave commented if using SHELLY_DEVICES_FILE)
# SHELLY_DEVICES=[{"name":"living_room_plus1pm","baseUrl":"http://192.168.1.50"}]

# Request timeout in milliseconds
SHELLY_TIMEOUT_MS=5000

# Optional discovery defaults file used by discovery tools
# SHELLY_DISCOVERY_CONFIG_FILE=./discovery.config.json