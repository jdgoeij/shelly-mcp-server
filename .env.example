# Option A: point to a JSON file with your devices (recommended)
SHELLY_DEVICES_FILE=./devices.local.json

# Option B: inline JSON (leave commented if using SHELLY_DEVICES_FILE)
# SHELLY_DEVICES=[{"name":"living_room_plus1pm","baseUrl":"http://192.168.1.50"}]

# Request timeout in milliseconds
SHELLY_TIMEOUT_MS=5000

# Optional discovery defaults file used by discovery tools
# SHELLY_DISCOVERY_CONFIG_FILE=./discovery.config.json

# Optional Shelly Cloud enrichment via auth_key (used when enrichCloud=true)
# Run 'npm run setup-cloud' to connect — stores credentials in ~/.shelly-mcp/credentials.json
# This works across all MCP clients (VS Code, Claude Desktop, Cursor, etc.)
# Override with env vars if needed:
# SHELLY_CLOUD_AUTH_KEY=your_auth_key_here
# SHELLY_CLOUD_SERVER=shelly-205-eu.shelly.cloud
# SHELLY_CLOUD_TIMEOUT_MS=10000
